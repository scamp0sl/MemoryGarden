# Application
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Database
# SQLAlchemy async 사용 시 postgresql+asyncpg:// 형식 필요
# Alembic 동기 마이그레이션 시에는 자동으로 postgresql:// 변환됨
DATABASE_URL=postgresql://memgarden:password@localhost:5432/memory_garden
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI Services
CLAUDE_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
GPT_MODEL=gpt-4o-2024-08-06

# Kakao
KAKAO_REST_API_KEY=
KAKAO_ADMIN_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_CHANNEL_ID=_ZeUTxl
KAKAO_MOCK_MODE=true
KAKAO_REDIRECT_URI=http://localhost:8001/api/v1/auth/kakao/callback

# 카카오 비즈메시지 (채널→구독자 친구톡 발송)
# 카카오 i 커넥트 메시지 서비스 가입 후 발급
# 신청: https://business.kakao.com → 카카오톡 비즈메시지 신청
KAKAO_BIZ_CLIENT_ID=
KAKAO_BIZ_CLIENT_SECRET=
KAKAO_SENDER_KEY=          # 발신프로파일키 (40자, 비즈메시지 콘솔에서 발급)

# Firebase Cloud Messaging (푸시 알림)
FIREBASE_CREDENTIALS_PATH=config/firebase-adminsdk.json
FIREBASE_PROJECT_ID=
KAKAO_CHANNEL_DEEP_LINK=kakaotalk://talk/chat/_ZeUTxl

# Firebase Web Push (Web App용 - Firebase Console에서 확인)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Monitoring
SENTRY_DSN=
